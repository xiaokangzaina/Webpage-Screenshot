{
  "screenshot_settings": {
    "description": "默认截图参数",
    "hint": "这些是默认截图参数。前端页面中单个群聊填写的截图参数会优先覆盖这里。",
    "type": "object",
    "items": {
      "default_viewport_width": {
        "description": "默认浏览器窗口宽度",
        "type": "int",
        "default": 1280
      },
      "default_viewport_height": {
        "description": "默认浏览器窗口高度",
        "type": "int",
        "default": 720
      },
      "default_wait_seconds": {
        "description": "默认页面等待秒数",
        "hint": "网页加载慢就调大。",
        "type": "float",
        "default": 5
      }
    }
  },
  "advanced_settings": {
    "description": "高级设置",
    "hint": "一般无需修改。",
    "type": "object",
    "items": {
      "platform": {
        "description": "底层发送平台",
        "hint": "一般保持默认即可。QQ 群聊和私聊使用 aiocqhttp。",
        "type": "string",
        "options": [
          "aiocqhttp"
        ],
        "default": "aiocqhttp"
      }
    }
  }
}
